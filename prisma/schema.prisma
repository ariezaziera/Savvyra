generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH (untouched — NextAuth managed)
// ============================================================

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String?
  name                String?
  image               String?
  emailVerified       DateTime?
  googleId            String?              @unique
  provider            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  accounts            Account[]
  sessions            Session[]
  webAuthnCredentials WebAuthnCredential[]
  salaryProfile       SalaryProfile?
  salaryMonths        SalaryMonth[]
  savingsAccounts     SavingsAccount[]
  savingsGoals        SavingsGoal[]
  investmentAccounts  InvestmentAccount[]
  investments         Investment[]
  debts               Debt[]
  commitments         Commitment[]
  commitmentInstances CommitmentInstance[]
  transactions        Transaction[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  categories          Category[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    String
  counter      Int       @default(0)
  deviceName   String?
  createdAt    DateTime  @default(now())
  lastUsed     DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// SAVINGS
// ============================================================

model SavingsAccount {
  id           String        @id @default(cuid())
  userId       String
  name         String
  bank         String
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoals SavingsGoal[]

  @@index([userId])
}

model SavingsGoal {
  id                  String          @id @default(cuid())
  userId              String
  savingsAccountId    String?
  name                String
  targetAmount        Float
  monthlyContribution Float?
  deadline            DateTime?
  note                String?
  isArchived          Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  user                User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsAccount      SavingsAccount? @relation(fields: [savingsAccountId], references: [id], onDelete: SetNull)
  transactions        Transaction[]

  @@index([userId])
  @@index([savingsAccountId])
}

// ============================================================
// INVESTMENT
// ============================================================

model InvestmentAccount {
  id                      String       @id @default(cuid())
  userId                  String
  name                    String
  platform                String
  type                    String       @default("General")
  note                    String?
  isGold                  Boolean      @default(false)
  goldCurrentPricePerGram Float?
  goldCustomPricePerGram  Float?
  goldPriceUpdatedAt      DateTime?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  investments             Investment[]

  @@index([userId])
}

model Investment {
  id                  String            @id @default(cuid())
  userId              String
  investmentAccountId String
  name                String
  purpose             String?
  type                String            @default("General")
  subType             String?
  monthlyContribution Float             @default(0)
  returnRate          Float             @default(0)
  startDate           DateTime          @default(now())
  maturityDate        DateTime?
  status              InvestmentStatus  @default(ACTIVE)
  goldGrams           Float?
  targetGoldGrams     Float?
  note                String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  investmentAccount   InvestmentAccount @relation(fields: [investmentAccountId], references: [id], onDelete: Cascade)
  transactions        Transaction[]

  @@index([userId])
  @@index([investmentAccountId])
}

// ============================================================
// DEBT
// ============================================================

model Debt {
  id               String         @id @default(cuid())
  userId           String
  name             String
  creditor         String?
  debtType         DebtType       @default(FIXED)
  category         String         @default("General")
  totalAmount      Float
  remainingAmount  Float
  monthlyPayment   Float          @default(0)
  interestRate     Float          @default(0)
  startDate        DateTime       @default(now())
  firstPaymentDate DateTime?
  totalInstalments Int?
  status           DebtStatus     @default(ACTIVE)
  note             String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  user             User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules        DebtSchedule[]
  commitments      Commitment[]
  transactions     Transaction[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, debtType])
}

model DebtSchedule {
  id            String         @id @default(cuid())
  debtId        String
  userId        String
  instalmentNo  Int
  dueDate       DateTime
  amount        Float
  status        ScheduleStatus @default(PENDING)
  paidAt        DateTime?
  note          String?
  createdAt     DateTime       @default(now())
  debt          Debt           @relation(fields: [debtId], references: [id], onDelete: Cascade)
  transaction   Transaction?

  @@index([debtId])
  @@index([userId])
  @@index([dueDate])
}

// ============================================================
// COMMITMENT
// ============================================================

model Commitment {
  id          String              @id @default(cuid())
  userId      String
  name        String
  amount      Float
  category    String              @default("General")
  frequency   CommitmentFreq      @default(MONTHLY)
  startDate   DateTime            @default(now())
  endDate     DateTime?
  dayOfMonth  Int?
  debtId      String?
  note        String?
  isActive    Boolean             @default(true)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  debt        Debt?               @relation(fields: [debtId], references: [id], onDelete: SetNull)
  instances   CommitmentInstance[]

  @@index([userId])
  @@index([debtId])
}

model CommitmentInstance {
  id            String         @id @default(cuid())
  commitmentId  String
  userId        String
  month         Int
  year          Int
  dueDate       DateTime
  amount        Float
  status        ScheduleStatus @default(PENDING)
  isArrear      Boolean        @default(false)
  paidAt        DateTime?
  note          String?
  createdAt     DateTime       @default(now())
  commitment    Commitment     @relation(fields: [commitmentId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction   Transaction?

  @@unique([commitmentId, month, year])
  @@index([commitmentId])
  @@index([userId])
  @@index([month, year])
}

// ============================================================
// TRANSACTION (central ledger)
// ============================================================

model Transaction {
  id                   String          @id @default(cuid())
  userId               String
  title                String
  description          String?
  amount               Float
  type                 TransactionType
  category             String          @default("General")
  date                 DateTime        @default(now())
  note                 String?
  savingsGoalId        String?
  investmentId         String?
  debtId               String?
  debtScheduleId       String?         @unique
  commitmentInstanceId String?         @unique
  salaryMonthId        String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  user                 User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  savingsGoal          SavingsGoal?    @relation(fields: [savingsGoalId], references: [id], onDelete: SetNull)
  investment           Investment?     @relation(fields: [investmentId], references: [id], onDelete: SetNull)
  debt                 Debt?           @relation(fields: [debtId], references: [id], onDelete: SetNull)
  debtSchedule         DebtSchedule?   @relation(fields: [debtScheduleId], references: [id], onDelete: SetNull)
  commitmentInstance   CommitmentInstance? @relation(fields: [commitmentInstanceId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([date])
  @@index([type])
  @@index([savingsGoalId])
  @@index([investmentId])
  @@index([debtId])
}

// ============================================================
// SALARY
// ============================================================

model SalaryProfile {
  id               String      @id @default(cuid())
  userId           String      @unique
  basicSalary      Float       @default(0)
  allowances       Json        @default("[]")
  epfRate          Float       @default(11)
  socsoRate        Float       @default(0.5)
  eisRate          Float       @default(0.2)
  customDeductions Json        @default("[]")
  otRate           Float       @default(1.5)
  doublePayRate    Float       @default(2.0)
  dailyRateFormula String      @default("basic/26")
  hoursPerDay      Float       @default(7.5)
  salaryDay        Int         @default(25)
  salaryBasis      String      @default("monthly")
  deductEPF        Boolean     @default(true)
  deductSOCSO      Boolean     @default(true)
  deductEIS        Boolean     @default(true)
  updatedAt        DateTime    @updatedAt
  user             User        @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model SalaryMonth {
  id                 String          @id @default(cuid())
  userId             String
  month              Int
  year               Int
  basicSalary        Float
  allowances         Json            @default("[]")
  otHours            Float           @default(0)
  otRate             Float           @default(1.5)
  doublePayHours     Float           @default(0)
  doublePayRate      Float           @default(2.0)
  unpaidLeaveDays    Float           @default(0)
  annualLeaveDays    Float           @default(0)
  medicalLeaveDays   Float           @default(0)
  replacementDays    Float           @default(0)
  dailyRateFormula   String          @default("basic/26")
  hoursPerDay        Float           @default(7.5)
  epfRate            Float
  socsoRate          Float
  eisRate            Float
  customDeductions   Json            @default("[]")
  grossSalary        Float
  epfAmount          Float
  socsoAmount        Float
  eisAmount          Float
  customDeductTotal  Float           @default(0)
  expectedNet        Float
  actualNet          Float?
  bankBalance        Float?
  fixedReserve       Float?
  usableBalance      Float?
  planItems          Json            @default("[]")
  isPlanFinalized    Boolean         @default(false)
  isMarkedReceived   Boolean         @default(false)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  user               User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  salaryPlanItems    SalaryPlanItem[]

  @@unique([userId, month, year])
  @@index([userId])
}

model SalaryPlanItem {
  id            String      @id @default(cuid())
  salaryMonthId String
  userId        String
  label         String
  amount        Float
  sourceType    String?
  sourceId      String?
  isIncluded    Boolean     @default(true)
  sortOrder     Int         @default(0)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  salaryMonth   SalaryMonth @relation(fields: [salaryMonthId], references: [id], onDelete: Cascade)

  @@index([salaryMonthId])
  @@index([userId])
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  deviceName String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================================
// CATEGORY
// ============================================================

model Category {
  id        String   @id @default(cuid())
  userId    String?
  name      String
  icon      String   @default("📦")
  type      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, type])
  @@index([userId])
}

// ============================================================
// ENUMS
// ============================================================

enum TransactionType {
  INCOME
  EXPENSE
  SAVINGS
  INVESTMENT
  DEBT_PAYMENT
  DEBT_ADDITION
  COMMITMENT
}

enum NotificationType {
  SALARY_REMINDER
  BILL_DUE
  SAVINGS_MILESTONE
  DEBT_REMINDER
  INVESTMENT_UPDATE
  GENERAL
}

enum DebtType {
  FIXED
  FLEXIBLE
  BNPL
}

enum DebtStatus {
  ACTIVE
  SETTLED
  PAUSED
}

enum CommitmentFreq {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

enum InvestmentStatus {
  ACTIVE
  MATURED
  WITHDRAWN
  CLOSED
}

enum ScheduleStatus {
  PENDING
  PAID
  OVERDUE
  SKIPPED
}