generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                  String               @id @default(cuid())
  email               String               @unique
  password            String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  name                String?
  emailVerified       DateTime?
  googleId            String?              @unique
  image               String?
  provider            String?
  accounts            Account[]
  categories          Category[]
  commitments         Commitment[]
  debts               Debt[]
  investments         Investment[]
  notifications       Notification[]
  pushSubscriptions   PushSubscription[]
  salaryMonths        SalaryMonth[]
  salaryProfile       SalaryProfile?
  savingsGoals        SavingsGoal[]
  sessions            Session[]
  transactions        Transaction[]
  webAuthnCredentials WebAuthnCredential[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SavingsGoal {
  id                  String        @id @default(cuid())
  name                String
  targetAmount        Float
  currentAmount       Float         @default(0)
  deadline            DateTime?
  userId              String
  createdAt           DateTime      @default(now())
  monthlyContribution Float?
  updatedAt           DateTime      @updatedAt
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions        Transaction[]

  @@index([userId])
}

model Transaction {
  id            String          @id @default(cuid())
  description   String?
  amount        Float
  date          DateTime        @default(now())
  userId        String
  savingsGoalId String?
  category      String
  status        String          @default("Completed")
  title         String
  type          TransactionType
  savingsGoal   SavingsGoal?    @relation(fields: [savingsGoalId], references: [id])
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([savingsGoalId])
}

model Commitment {
  id        String   @id @default(cuid())
  name      String
  amount    Float
  dueDate   DateTime
  isPaid    Boolean  @default(false)
  userId    String
  category  String   @default("General")
  createdAt DateTime @default(now())
  frequency String   @default("Monthly")
  note      String?
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, dueDate])
}

model Category {
  id        String   @id @default(cuid())
  name      String
  icon      String
  type      String
  isDefault Boolean  @default(false)
  userId    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name, type])
  @@index([userId])
}

/// Persistent salary settings — auto-prefills next month's calculator
model SalaryProfile {
  id               String   @id @default(cuid())
  userId           String   @unique
  basicSalary      Float
  allowances       Json     @default("[]")
  epfRate          Float    @default(11)
  socsoRate        Float    @default(0.5)
  eisRate          Float    @default(0.2)
  customDeductions Json     @default("[]")
  otRate           Float    @default(1.5)
  doublePayRate    Float    @default(2.0)
  dailyRateFormula String   @default("basic/26")
  updatedAt        DateTime @updatedAt
  salaryDay        Int      @default(2)
  deductEIS        Boolean  @default(true)
  deductEPF        Boolean  @default(true)
  deductSOCSO      Boolean  @default(true)
  hoursPerDay      Float    @default(7.5)
  salaryBasis      String   @default("monthly")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// One record per calendar month
model SalaryMonth {
  id                String   @id @default(cuid())
  userId            String
  month             Int
  year              Int
  basicSalary       Float
  allowances        Json     @default("[]")
  epfRate           Float
  socsoRate         Float
  eisRate           Float
  customDeductions  Json     @default("[]")
  otRate            Float
  doublePayRate     Float
  dailyRateFormula  String   @default("basic/26")
  unpaidLeaveDays   Float    @default(0)
  annualLeaveDays   Float    @default(0)
  medicalLeaveDays  Float    @default(0)
  replacementDays   Float    @default(0)
  otHours           Float    @default(0)
  doublePayHours    Float    @default(0)
  grossSalary       Float
  epfAmount         Float
  socsoAmount       Float
  eisAmount         Float
  customDeductTotal Float
  expectedNet       Float
  actualNet         Float?
  allocations       Json     @default("[]")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  hoursPerDay       Float    @default(7.5)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month, year])
  @@index([userId])
}

model WebAuthnCredential {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    String
  counter      Int       @default(0)
  deviceName   String?
  createdAt    DateTime  @default(now())
  lastUsed     DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}

model PushSubscription {
  id         String   @id @default(cuid())
  userId     String
  endpoint   String   @unique
  p256dh     String
  auth       String
  deviceName String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Debt {
  id              String    @id @default(cuid())
  userId          String
  name            String
  creditor        String?
  totalAmount     Float
  remainingAmount Float
  monthlyPayment  Float     @default(0)
  interestRate    Float?    @default(0)
  dueDate         DateTime?
  nextPaymentDate DateTime?
  category        String    @default("General")
  status          String    @default("ACTIVE")
  note            String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  creditLimit     Float?
  debtType        String    @default("FIXED")
  minimumPayment  Float?    @default(0)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, debtType])
}

model Investment {
  id                  String    @id @default(cuid())
  userId              String
  name                String
  platform            String?
  type                String    @default("General")
  principalAmount     Float
  currentValue        Float     @default(0)
  monthlyContribution Float?    @default(0)
  returnRate          Float?    @default(0)
  startDate           DateTime  @default(now())
  maturityDate        DateTime?
  status              String    @default("ACTIVE")
  note                String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

enum NotificationType {
  SALARY_REMINDER
  BILL_DUE
  SAVINGS_MILESTONE
  GENERAL
}

enum TransactionType {
  INCOME
  EXPENSE
  DEBT
  COMMITMENT
  SAVINGS
  INVESTMENT
}

