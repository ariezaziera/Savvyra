generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Transaction {
  id            Int          @id @default(autoincrement())
  title         String
  category      String
  amount        Float
  type          String
  status        String
  date          DateTime
  createdAt     DateTime     @default(now())
  savingsGoalId Int?
  savingsGoal   SavingsGoal? @relation(fields: [savingsGoalId], references: [id])
}

model SavingsGoal {
  id        Int       @id @default(autoincrement())
  name      String
  category  String
  target    Float
  current   Float     @default(0)
  deadline  DateTime?
  note      String?
  createdAt DateTime  @default(now())

  transactions Transaction[]
}

model Commitment {
  id        Int      @id @default(autoincrement())
  name      String
  category  String
  amount    Float
  dueDate   DateTime
  frequency String // Monthly, Weekly, etc
  status    String // Upcoming, Paid, Overdue
  note      String?
  createdAt DateTime @default(now())
}
