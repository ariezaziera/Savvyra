// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  password      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  savingsGoals  SavingsGoal[]
  transactions  Transaction[]
  commitments   Commitment[]
}

model SavingsGoal {
  id          String        @id @default(cuid())
  name        String
  targetAmount Float
  currentAmount Float        @default(0)
  deadline    DateTime?
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  transactions Transaction[] // 👈 opposite relation to Transaction

  @@index([userId])
}

model Transaction {
  id          String       @id @default(cuid())
  description String
  amount      Float
  type        String       // "income" or "expense"
  date        DateTime     @default(now())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Optional relation to SavingsGoal (if this transaction contributes to a goal)
  savingsGoalId String?
  savingsGoal   SavingsGoal? @relation(fields: [savingsGoalId], references: [id])

  @@index([userId])
  @@index([savingsGoalId])
}

model Commitment {
  id          String   @id @default(cuid())
  name        String
  amount      Float
  dueDate     DateTime
  isPaid      Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}